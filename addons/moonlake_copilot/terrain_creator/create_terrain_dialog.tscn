[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/moonlake_copilot/create_terrain_dialog.gd" id="1"]

[node name="CreateTerrainDialog" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="TitleLabel" type="Label" parent="."]
layout_mode = 2
theme_type_variation = &"HeaderLarge"
text = "Create Terrain"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="."]
layout_mode = 2

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2

[node name="DescriptionLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Configure your terrain settings:"
autowrap_mode = 2

[node name="SpacerTop" type="Control" parent="MarginContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="SettingsGrid" type="GridContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
columns = 2

[node name="SizeLabel" type="Label" parent="MarginContainer/VBoxContainer/SettingsGrid"]
layout_mode = 2
text = "Terrain Size:"

[node name="SizeOption" type="OptionButton" parent="MarginContainer/VBoxContainer/SettingsGrid"]
layout_mode = 2
size_flags_horizontal = 3
selected = 1
item_count = 3
popup/item_0/text = "Small (512x512)"
popup/item_0/id = 0
popup/item_1/text = "Medium (1024x1024)"
popup/item_1/id = 1
popup/item_2/text = "Large (2048x2048)"
popup/item_2/id = 2

[node name="HeightScaleLabel" type="Label" parent="MarginContainer/VBoxContainer/SettingsGrid"]
layout_mode = 2
text = "Height Scale:"

[node name="HeightScaleSpinBox" type="SpinBox" parent="MarginContainer/VBoxContainer/SettingsGrid"]
layout_mode = 2
min_value = 1.0
max_value = 1000.0
value = 100.0

[node name="SpacerBottom" type="Control" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="HSeparator2" type="HSeparator" parent="."]
layout_mode = 2

[node name="ButtonContainer" type="HBoxContainer" parent="."]
layout_mode = 2
alignment = 2

[node name="CancelButton" type="Button" parent="ButtonContainer"]
custom_minimum_size = Vector2(100, 0)
layout_mode = 2
text = "Cancel"

[node name="CreateButton" type="Button" parent="ButtonContainer"]
custom_minimum_size = Vector2(100, 0)
layout_mode = 2
text = "Create"

[connection signal="pressed" from="ButtonContainer/CancelButton" to="." method="_on_cancel_pressed"]
[connection signal="pressed" from="ButtonContainer/CreateButton" to="." method="_on_create_pressed"]
